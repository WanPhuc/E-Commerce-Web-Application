@{
    // Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Admin/_AdminShared.css" asp-append-version="true" />

</head>

<body>
    <div class="container-fluid p-0">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar bg-dark text-white  d-flex flex-column">

            <h5 class="text-center mt-3 mb-3">Admin Panel</h5>

            <!-- MENU -->
            <div class="flex-grow-1 overflow-auto pe-1">
                <ul class="nav nav-pills flex-column gap-1">
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Seller" asp-action="Index">
                            <i class="bi bi-tags me-2"></i> Seller
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Users" asp-action="Index">
                            <i class="bi bi-people me-2"></i> Users
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Categories" asp-action="Index">
                            <i class="bi bi-tags me-2"></i> Categories
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Orders" asp-action="Index">
                            <i class="bi bi-bag-check me-2"></i> Orders
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Products" asp-action="Index">
                            <i class="bi bi-box-seam me-2"></i> Products
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-area="Admin" asp-controller="Roles" asp-action="Index">
                            <i class="bi bi-people me-2"></i> Roles
                        </a>
                    </li>
                </ul>
            </div>

            <!-- PROFILE -->
            <div class="p-3 border-top border-secondary text-center">
                <img src="~/images/user.png"
                     class="rounded-circle border mb-2"
                     style="width:80px;height:80px;object-fit:cover;" />

                <div class="fw-semibold text-truncate mb-3">
                    @User.Identity?.Name
                </div>

                <a class="btn btn-outline-danger w-100"
                     asp-area=""
                   asp-controller="Login"
                   asp-action="Logout">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="admin-main p-4">
            @RenderBody()
        </main>

    </div>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>
